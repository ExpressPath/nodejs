NODE_ENV=production
PORT=3000
HELPER_HTTP_PORT=80

HELPER_API_KEY=replace-with-long-random-string
HELPER_PUBLIC_BASE_URL=http://YOUR_STATIC_IP_OR_DOMAIN
HELPER_ALLOWED_ORIGINS=https://YOUR_VERCEL_DOMAIN

NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

HELPER_AUTO_SCHEMA_BOOTSTRAP=true
HELPER_MEMORY_SCHEMA_FALLBACK=false

GITHUB_EXECUTION_ENABLED=true
GITHUB_EXECUTION_TOKEN=
GITHUB_EXECUTION_REPOSITORY=ExpressPath/nodejs
GITHUB_EXECUTION_WORKFLOW=ivucx-proof-executor.yml
GITHUB_EXECUTION_REF=main
GITHUB_EXECUTION_TIMEOUT_MS=30000
GITHUB_EXECUTION_SYNC_WAIT_TIMEOUT_MS=45000
GITHUB_EXECUTION_SYNC_WAIT_POLL_MS=1500

HELPER_MAX_CODE_BYTES=200000
