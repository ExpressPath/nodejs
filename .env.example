PORT=3000
HELPER_API_KEY=
ALLOW_ANONYMOUS_HELPER=true

# Optional: delegate proof checking to the Render-hosted iVucx app.
# Example: https://your-ivucx-app.onrender.com
EXECUTION_SERVER_BASE_URL=
EXECUTION_SERVER_API_KEY=
EXECUTION_SERVER_TIMEOUT_MS=180000

LEAN_CMD=lean
COQ_CMD=coqc

LEAN_LAMBDA_CMD=node
LEAN_LAMBDA_ARGS=tools/convert-lean.cjs --out {out}
COQ_LAMBDA_CMD=node
COQ_LAMBDA_ARGS=tools/convert-coq.cjs --out {out}

LEAN_CIC_CMD=node
LEAN_CIC_ARGS=tools/convert-lean-cic.cjs --out {out}
COQ_CIC_CMD=node
COQ_CIC_ARGS=tools/convert-coq-cic.cjs --out {out}
LEAN4EXPORT_CMD=lake
LEAN4EXPORT_ARGS=env {bin} {module}
LEAN4EXPORT_BIN=/opt/lean4export/.lake/build/bin/lean4export

# Built-in Coq CIC export uses MetaRocq.
# Override these only if you want to use a different exact exporter.
# COQ_CIC_EXPORT_CMD=<your exact exporter command>
# COQ_CIC_EXPORT_ARGS=<your args using {file} and {out}>
